<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews
    </IfModule>

    <FilesMatch "\.(eot|otf|ttf|woff|woff2|jpg|jpeg|png|gif|webp|svg|ico)$">
        Header always set Access-Control-Allow-Origin "*"
    </FilesMatch>

    RewriteEngine On

    # Force WWW
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

    # Laravel public folder handling
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ ^$1 [N]

    RewriteCond %{REQUEST_URI} (\.\w+$) [NC]
    RewriteRule ^(.*)$ public/$1 [L]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ public/index.php [L]
</IfModule>

# BEGIN cPanel-generated php ini directives
<IfModule php_module>
    php_flag display_errors On
    php_value max_execution_time 300
    php_value max_input_time 80
    php_value max_input_vars 1000
    php_value memory_limit 1G
    php_value post_max_size 50M

    # FIX SESSION ERROR
    php_value session.gc_probability 1
    php_value session.gc_divisor 1000
    php_value session.gc_maxlifetime 1440
    php_value session.save_path "/var/cpanel/php/sessions/ea-php84"

    php_value upload_max_filesize 10M
    php_flag zlib.output_compression Off
</IfModule>

<IfModule lsapi_module>
    php_flag display_errors On
    php_value max_execution_time 300
    php_value max_input_time 80
    php_value max_input_vars 1000
    php_value memory_limit 1G
    php_value post_max_size 50M

    # FIX SESSION ERROR
    php_value session.gc_probability 1
    php_value session.gc_divisor 1000
    php_value session.gc_maxlifetime 1440
    php_value session.save_path "/var/cpanel/php/sessions/ea-php84"

    php_value upload_max_filesize 10M
    php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives

# PHP 8.4 Handler
<IfModule mime_module>
    AddHandler application/x-httpd-alt-php84 .php .php8 .phtml
    AddHandler application/x-httpd-alt-php84___lsphp .php .php8 .phtml
</IfModule>
